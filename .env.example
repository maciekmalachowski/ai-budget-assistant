# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key: Supabase dashboard → Settings → API,
# or from `supabase start` output when running locally.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used by the import pipeline. NEVER expose to the
# browser and NEVER commit. (Phase 3+)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
# Server-only. Create at https://console.anthropic.com (pay-as-you-go). (Phase 4+)
ANTHROPIC_API_KEY=
# Model IDs — override to tune cost/quality.
ANTHROPIC_MODEL_CATEGORIZE=claude-haiku-4-5
ANTHROPIC_MODEL_QA=claude-sonnet-4-6
ANTHROPIC_MODEL_INSIGHTS=claude-sonnet-4-6

# ─── App ─────────────────────────────────────────────────────────────────────
# Primary reporting currency (ISO 4217).
NEXT_PUBLIC_DEFAULT_CURRENCY=PLN
