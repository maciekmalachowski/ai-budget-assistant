# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# brainstorming visual companion sessions
.superpowers/

# git worktrees
.worktrees/

# Claude Code / ruflo — track hand-authored config, ignore generated + runtime.
# .claude/ is mostly ruflo-generated (regenerable via `ruflo init`); we version only
# settings.json + the project CLAUDE.md (at repo root) for reproducibility.
.claude/*
!.claude/settings.json
.claude/settings.local.json

# ruflo runtime state (swarm records, vector stores, locks)
.claude-flow/
.swarm/
*.rvf
*.rvf.lock
ruvector.db

# stray 0-byte files from shell-quoting mishaps (safe to delete manually)
/{,
/{,+
/0
/450
/console.log('ERR'
/r.merchant
/t.rawDescription
/the
